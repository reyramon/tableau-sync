                    <ProjectItem
            Name="ScriptMain.cs"
            Encoding="UTF8"><![CDATA[#region Namespaces
using System;
using Microsoft.SqlServer.Dts.Runtime;
using TableauUserSync.ScriptTasks;
#endregion

namespace ST_7527d6142c4b4d4ab5bcd2579d4a97c1
{
    [Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
    public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
    {
        public void Main()
        {
            bool fireAgain = false;

            try
            {
                SignInScriptTask signInTask = new SignInScriptTask();
                string serverUrl = (string)Dts.Variables["User::ServerUrl"].Value;
                string apiVersion = (string)Dts.Variables["User::ApiVersion"].Value;
                string patName = (string)Dts.Variables["User::PatName"].Value;
                string patSecret = (string)Dts.Variables["User::PatSecret"].Value;
                string siteContentUrl = (string)Dts.Variables["User::SiteContentUrl"].Value;

                TableauUserSync.ScriptTasks.Common.TableauSignInResult result = signInTask.Execute(
                    serverUrl,
                    apiVersion,
                    patName,
                    patSecret,
                    siteContentUrl);

                Dts.Variables["User::Token"].Value = result.Token;
                Dts.Variables["User::SiteId"].Value = result.SiteId;

                Dts.Events.FireInformation(0, "Tableau Sign In", "Authenticated to Tableau and stored Token/SiteId.", string.Empty, 0, ref fireAgain);
                Dts.TaskResult = (int)ScriptResults.Success;
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Tableau Sign In", ex.ToString(), string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        }
    }
}]]></ProjectItem>
          <ProjectItem
            Name="SignInScriptTask.cs"
            Encoding="UTF8"><![CDATA[using System;
using TableauUserSync.ScriptTasks.Common;

namespace TableauUserSync.ScriptTasks
{
    internal sealed class SignInScriptTask
    {
        public TableauSignInResult Execute(string serverUrl, string apiVersion, string patName, string patSecret, string siteContentUrl)
        {
            TableauRestClient client = new TableauRestClient();
            return client.SignIn(serverUrl, apiVersion, patName, patSecret, siteContentUrl);
        }
    }
}]]></ProjectItem>
